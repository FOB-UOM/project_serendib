{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "pillar-education-human-development/art-literature-culture record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_id",
    "pillar",
    "sub_pillar",
    "title",
    "content",
    "language",
    "provenance",
    "license",
    "review_status",
    "created_at"
  ],
  "properties": {
    "record_id": {
      "type": "string",
      "minLength": 3
    },
    "pillar": {
      "type": "string",
      "const": "pillar-education-human-development"
    },
    "sub_pillar": {
      "type": "string",
      "const": "art-literature-culture"
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "content": {
      "type": "string",
      "minLength": 10
    },
    "language": {
      "type": "string",
      "enum": [
        "si",
        "en",
        "ta"
      ]
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_name",
        "source_type",
        "collected_at",
        "collector"
      ],
      "properties": {
        "source_name": {
          "type": "string",
          "minLength": 2
        },
        "source_type": {
          "type": "string",
          "enum": [
            "field_note",
            "policy",
            "public_document",
            "classroom_input"
          ]
        },
        "collected_at": {
          "type": "string",
          "format": "date"
        },
        "collector": {
          "type": "string",
          "minLength": 2
        }
      }
    },
    "license": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "url"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 2
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "review_status": {
      "type": "string",
      "enum": [
        "draft",
        "approved",
        "rejected"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "quality_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}