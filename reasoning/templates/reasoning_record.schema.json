{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Serendib Layer2 Reasoning Record",
  "type": "object",
  "required": ["id", "language", "domain", "question", "answer", "steps", "source"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "language": { "type": "string", "enum": ["si", "ta", "en", "mixed"] },
    "domain": { "type": "string", "minLength": 1 },
    "question": { "type": "string", "minLength": 1 },
    "answer": { "type": "string", "minLength": 1 },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["type", "content"],
        "properties": {
          "type": { "type": "string", "enum": ["explanation", "calculation", "rule", "check"] },
          "content": { "type": "string", "minLength": 1 }
        }
      }
    },
    "source": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "enum": ["human", "synthetic", "mixed"] },
        "provenance": { "type": "string" }
      }
    },
    "created_at": { "type": "string" }
  }
}

